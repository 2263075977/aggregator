{
  "domains": [],
  "crawl": {
    "enable": true,
    "exclude": "",
    "threshold": 5,
    "singlelink": false,
    "config": {
      "liveness": true,
      "ignorede": true,
      "exclude": "到期|Expire|Traffic|剩余流量|时间|官网|产品|联系"
    },
    "telegram": {
      "enable": true,
      "pages": 3,
      "exclude": "付费|广告|推广|机场推荐|官网|下载|apk|APK",
      "users": {
        "changfengchannel": {
          "push_to": ["free"]
        },
        "wangcai_8": {
          "push_to": ["free"]
        },
        "mfjdpd": {
          "exclude": "apk|APK|广告|推广|官网|下载",
          "push_to": ["free"]
        }
      }
    }
  },
  "groups": {
    "free": {
      "emoji": true,
      "list": true,
      "targets": {
        "clash": "free-clash"
      }
    }
  },
  "storage": {
    "engine": "gist",
    "items": {
      "free-clash": {
        "username": "your-github-username",
        "gistid": "your-gist-id",
        "filename": "free-clash.yaml"
      }
    }
  }
}
